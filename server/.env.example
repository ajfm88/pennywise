# MongoDB connection string (include database name before the ?)
# Local:  mongodb://localhost:27017/w-pennywise
# Atlas:  mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/<db-name>?appName=Cluster0
MONGODBURI=

# Secret used to sign JWT tokens — any long random string
JWT_SECRET=

# Cloudinary credentials (from cloudinary.com → Dashboard)
CLOUD_NAME=
CLOUD_API_KEY=
CLOUD_API_SECRET=

# URL of the frontend (used for CORS)
# Local:  http://localhost:3000
# Prod:   https://your-app.onrender.com
CLIENT_URL=

# Port the server listens on (optional, defaults to 8000)
PORT=8000

# OpenAI API key (from platform.openai.com → API keys)
OPENAI_API_KEY=
